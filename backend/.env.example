# --- Runtime -----------------------------------------------------------------
ENV=development
APP_NAME=fdm-tracker
LOG_LEVEL=INFO

# --- Database ----------------------------------------------------------------
# Postgres credentials. Required by docker-compose.yml for the `db` service.
# Pick a strong password locally; never commit this file.
POSTGRES_USER=fdm
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=fdm

# Connection string used by the API. When running via docker-compose this is
# overridden to point at the `db` service; for host-based dev use localhost.
# For DO managed Postgres: postgresql+psycopg2://user:pass@host:25060/fdm?sslmode=require
DATABASE_URL=postgresql+psycopg2://fdm:change-me-locally@localhost:5432/fdm

# --- Security ----------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-64-byte-urlsafe-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=720       # 12h
REFRESH_TOKEN_TTL_MIN=20160    # 14d
BCRYPT_ROUNDS=12

# --- HMAC / anti-spoof -------------------------------------------------------
HMAC_CLOCK_SKEW_SEC=300
MAX_KEYSTROKES_PER_MIN=1200
MAX_MOUSE_EVENTS_PER_MIN=6000

# --- CORS --------------------------------------------------------------------
# Comma-separated origins. For the Electron app set file:// or leave * internal.
CORS_ORIGINS=http://localhost:3000,https://admin.fdm-tracker.internal

# --- Signup ------------------------------------------------------------------
# Comma-separated email domains that /auth/signup will accept.
# Self-signup always produces role=user; admins are created via /admin/users.
ALLOWED_SIGNUP_DOMAINS=fourdm.com,fourdm.digital

# --- Email verification ------------------------------------------------------
# backend = "console" (dev), "gmail" (OAuth via Gmail API), or "smtp".
EMAIL_BACKEND=console
EMAIL_FROM=FDM Tracker <no-reply@fourdm.com>

# SMTP (only when EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Gmail API (only when EMAIL_BACKEND=gmail)
GMAIL_MODE=oauth
GMAIL_SENDER=no-reply@fourdm.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SERVICE_ACCOUNT_FILE=
GMAIL_IMPERSONATE=

VERIFICATION_CODE_TTL_MIN=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SEC=60

# --- Defaults ----------------------------------------------------------------
DEFAULT_IDLE_THRESHOLD_MIN=5
DEFAULT_WORKDAY_START_HOUR=4
DEFAULT_TIMEZONE=Asia/Kolkata
