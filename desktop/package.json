{
  "name": "fdm-tracker-desktop",
  "version": "0.1.5",
  "description": "FDM Tracker — employee-facing desktop client",
  "author": "Fourth Dimension Media Solutions",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "electron-vite build && electron-builder --dir",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "11.3.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.8.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.5",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^30.5.1",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.11",
    "typescript": "5.5.4",
    "vite": "^5.4.6"
  }
}
