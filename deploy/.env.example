# --- Domains (used by Caddy) -------------------------------------------------
# These must resolve via DNS A-record to your droplet's IP before `up`.
ADMIN_DOMAIN=admin.fourdm.services
API_DOMAIN=api.fourdm.services

# --- Admin build-time -------------------------------------------------------
# Baked into the Next.js bundle. MUST match API_DOMAIN.
NEXT_PUBLIC_API_BASE=https://api.fourdm.services
# Sentry DSN for the admin web (safe to expose; baked into the JS bundle).
NEXT_PUBLIC_SENTRY_DSN=

# --- Backend runtime --------------------------------------------------------
ENV=production
APP_NAME=fdm-tracker
LOG_LEVEL=INFO

# Database. SQLite is the only database. 4 slashes = the absolute path
# /data/fdm.db, which docker-compose.prod.yml mounts on the persistent
# `fdm_sqlite` named volume. See deploy/SQLITE_PROD.md.
DATABASE_URL=sqlite:////data/fdm.db

# Generate a fresh secret for production:
#   openssl rand -hex 64
JWT_SECRET=replace-me-with-a-real-64-byte-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=720
REFRESH_TOKEN_TTL_MIN=20160
BCRYPT_ROUNDS=12

HMAC_CLOCK_SKEW_SEC=300
MAX_KEYSTROKES_PER_MIN=1200
MAX_MOUSE_EVENTS_PER_MIN=6000

# Comma-separated list of admin/desktop origins
CORS_ORIGINS=https://admin.fourdm.services

DEFAULT_IDLE_THRESHOLD_MIN=5
DEFAULT_WORKDAY_START_HOUR=4
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Email -----------------------------------------------------------------
EMAIL_BACKEND=gmail
EMAIL_FROM=SocialPulse <no-reply@fourdm.com>

GMAIL_MODE=oauth
GMAIL_SENDER=SocialPulse <no-reply@fourdm.com>
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

GMAIL_SERVICE_ACCOUNT_FILE=
GMAIL_IMPERSONATE=

VERIFICATION_CODE_TTL_MIN=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SEC=60

# Sentry (optional). Get DSN from Sentry → Project → Settings → Client Keys.
SENTRY_DSN=
